<?xml version="1.0" encoding="utf-8"?>
<style xmlns="http://purl.org/net/xbiblio/csl" class="in-text" version="1.0" demote-non-dropping-particle="never" default-locale="en-US">
  <info>
    <title>Journal Author-Date Modified for Mendeley</title>
    <title-short>Journal Author-Date Modified</title-short>
    <id>http://www.zotero.org/styles/journal-author-date-modified-mendeley</id>
    <link href="http://www.zotero.org/styles/journal-author-date-modified-mendeley" rel="self"/>
    <author>
      <name>OpenAI</name>
    </author>
    <category citation-format="author-date"/>
    <category field="business"/>
    <summary>Custom author-date style based on the journal instructions: in-text citations like (Spender, 1995), bibliography examples for articles, books, and book chapters.</summary>
    <updated>2026-06-22T00:00:00+00:00</updated>
    <rights license="http://creativecommons.org/licenses/by-sa/3.0/">This work is licensed under a Creative Commons Attribution-ShareAlike 3.0 License</rights>
  </info>

  <macro name="author-bib">
    <names variable="author">
      <name name-as-sort-order="all" and="symbol" sort-separator=", " initialize-with="." delimiter=", " delimiter-precedes-last="always"/>
      <substitute>
        <names variable="editor"/>
        <text variable="title"/>
      </substitute>
    </names>
  </macro>

  <macro name="author-short">
    <names variable="author">
      <name form="short" and="symbol" delimiter=", " delimiter-precedes-last="always"/>
      <et-al font-style="normal"/>
      <substitute>
        <names variable="editor">
          <name form="short" and="symbol" delimiter=", " delimiter-precedes-last="always"/>
          <et-al font-style="normal"/>
        </names>
        <text variable="title" form="short"/>
      </substitute>
    </names>
  </macro>

  <macro name="year-citation">
    <choose>
      <if variable="issued">
        <date variable="issued">
          <date-part name="year"/>
        </date>
        <text variable="year-suffix"/>
      </if>
      <else-if variable="status">
        <text variable="status"/>
      </else-if>
      <else>
        <text value="n.d."/>
      </else>
    </choose>
  </macro>

  <macro name="year-bib">
    <choose>
      <if variable="issued">
        <date variable="issued" prefix="(" suffix=")">
          <date-part name="year"/>
        </date>
        <text variable="year-suffix"/>
      </if>
      <else-if variable="status">
        <text variable="status" prefix="(" suffix=")"/>
      </else-if>
      <else>
        <text value="(n.d.)"/>
      </else>
    </choose>
  </macro>

  <macro name="editor-bib-inbook">
    <names variable="editor">
      <name and="symbol" initialize-with="." delimiter=", " delimiter-precedes-last="always"/>
      <label form="short" text-case="capitalize-first" prefix=" (" suffix=".)"/>
    </names>
  </macro>

  <macro name="publisher-block">
    <group delimiter=": ">
      <text variable="publisher-place"/>
      <text variable="publisher"/>
    </group>
  </macro>

  <macro name="journal-block">
    <group delimiter=", ">
      <text variable="container-title"/>
      <group delimiter="">
        <text variable="volume"/>
        <text variable="issue" prefix="(" suffix=")"/>
      </group>
      <text variable="page"/>
    </group>
  </macro>

  <citation et-al-min="3" et-al-use-first="1" disambiguate-add-year-suffix="true" collapse="year-suffix">
    <sort>
      <key macro="author-short"/>
      <key macro="year-citation"/>
    </sort>
    <layout prefix="(" suffix=")" delimiter="; ">
      <group delimiter=", ">
        <text macro="author-short"/>
        <text macro="year-citation"/>
        <text variable="locator"/>
      </group>
    </layout>
  </citation>

  <bibliography hanging-indent="true" et-al-min="7" et-al-use-first="6" entry-spacing="0" line-spacing="1">
    <sort>
      <key macro="author-bib"/>
      <key macro="year-bib"/>
      <key variable="title"/>
    </sort>
    <layout suffix=".">
      <text macro="author-bib" suffix=" "/>
      <text macro="year-bib" suffix=". "/>
      <choose>
        <if type="article-journal article-magazine article-newspaper" match="any">
          <text variable="title" suffix=". "/>
          <text macro="journal-block"/>
        </if>
        <else-if type="chapter paper-conference" match="any">
          <text variable="title" suffix=". "/>
          <group delimiter=" ">
            <text variable="page" prefix="Pp. "/>
            <text value="in"/>
            <group delimiter=", ">
              <text macro="editor-bib-inbook"/>
              <group delimiter=", ">
                <text variable="container-title"/>
                <text variable="volume" prefix="Vol. "/>
              </group>
            </group>
          </group>
          <text macro="publisher-block" prefix=". "/>
        </else-if>
        <else-if type="book" match="any">
          <text variable="title" suffix=". "/>
          <text macro="publisher-block"/>
        </else-if>
        <else>
          <text variable="title" suffix=". "/>
          <choose>
            <if variable="container-title">
              <text macro="journal-block"/>
            </if>
            <else>
              <text macro="publisher-block"/>
            </else>
          </choose>
        </else>
      </choose>
    </layout>
  </bibliography>
</style>
